# 2. Your Firebase Realtime Database URL
# To find: Firebase Console > Build > Realtime Database > Data tab (visible at top)
# Format: https://PROJECT_ID.firebaseio.com
# Example: https://yonas-mobile-feedback.firebaseio.com
FIREBASE_DATABASE_URL=https://yonascustomerfeedback-default-rtdb.firebaseio.com

# 3. Admin Portal Password (change this in production!)
ADMIN_PASSWORD=yonasAdmin123

# 4. Node Environment
NODE_ENV=development

# 5. Optional: Google Gemini API Key (for AI features)
# GEMINI_API_KEY=your_gemini_api_key_here

# ======================================
# SETUP INSTRUCTIONS
# ======================================
# 1. Go to https://console.firebase.google.com
# 2. Create a new project or select existing one
# 3. Enable Realtime Database (Build > Realtime Database)
# 4. Go to Project Settings > Service Accounts
# 5. Click "Generate New Private Key"
# 6. Copy the entire JSON and paste as FIREBASE_SERVICE_ACCOUNT_KEY value
# 7. Get your database URL from Realtime Database tab
# 8. Set ADMIN_PASSWORD to your preferred password
# 9. Save this file as .env.local
# 10. Run: npm install && npm run dev
